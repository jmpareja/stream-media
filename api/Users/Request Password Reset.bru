meta {
  name: Request Password Reset
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/users/password-reset/request
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "identifier": "jpareja@example.com"
  }
}

script:post-response {
  if (res.status === 200 && res.body.reset_token) {
    bru.setVar("resetToken", res.body.reset_token);
  }
}
